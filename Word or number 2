
n = int(input())
line = []
for _ in range(n):
    w = input()
    line.append(w)

words = []
digits = []

for a in line:
    if a.isdigit():
        digits.append(a)
    else:
        words.append(a)


if not words:
    print("no words")
else:
    print('-'.join([x for x in words]))

if not digits:
    print(0)
else:
    print(sum([int(x) for x in digits]))
